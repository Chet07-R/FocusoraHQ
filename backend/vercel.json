{
  "version": 2,
  "buildCommand": "npm install && npm run build",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/api/:path(.*)",
      "destination": "https://your-api-domain.vercel.app/api/:path"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}